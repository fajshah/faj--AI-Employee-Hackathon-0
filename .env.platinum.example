# Platinum Tier AI Employee System - Cloud Environment Configuration
# ==================================================================
# Copy this file to .env.platinum and fill in your actual credentials
# NEVER commit .env.platinum to version control

# ============================================
# SECURITY BOUNDARY NOTICE
# ============================================
# This configuration is for CLOUD components only.
# Cloud components:
# - READ data from sources
# - GENERATE drafts and briefings
# - WRITE to Pending_Approval directory
# - NEVER execute external actions (email send, LinkedIn post, WhatsApp, payments)
# - NEVER store OAuth tokens or session credentials
# Local components handle all execution after human approval

# ============================================
# CLOUD INFRASTRUCTURE
# ============================================

# Base directory for cloud operations (local path for sync)
CLOUD_BASE_DIR=.

# Cloud storage type: local, s3, azure, gcs
CLOUD_STORAGE_TYPE=local

# Cloud storage bucket/container name (if using cloud storage)
# CLOUD_STORAGE_BUCKET=my-ai-employee-bucket

# Enable Git vault sync for audit trail
GIT_SYNC_ENABLED=false
GIT_VAULT_PATH=.vault
GIT_BRANCH=main

# ============================================
# CLAUDE API (AI Reasoning & Draft Generation)
# ============================================

CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Optional: OpenAI fallback
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# GMAIL API (Read-Only for Cloud Watcher)
# ============================================
# Cloud watcher READS emails only - never sends

GMAIL_API_ENABLED=true
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_TOKEN_FILE=tokens/gmail_token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Gmail monitoring configuration
GMAIL_SCAN_INTERVAL=60
GMAIL_MAX_RESULTS=50
GMAIL_LABEL_IDS=INBOX

# ============================================
# BRAND VOICE CONFIGURATION
# ============================================

COMPANY_NAME=Your Company Name
CEO_NAME=CEO
BRAND_TONE=professional
BRAND_STYLE=friendly
EMAIL_SIGNATURE=Best regards,\nThe Team

# Words to avoid in generated content (comma-separated)
BRAND_AVOID_WORDS=guarantee,promise,confidential

# Preferred phrases to include (comma-separated)
BRAND_PREFERRED_PHRASES=value-driven,customer-focused

# ============================================
# BRIEFING SCHEDULE
# ============================================

# Weekly CEO briefing schedule
BRIEFING_DAY=sunday
BRIEFING_TIME=18:00

# ============================================
# MONITORING & LOGGING
# ============================================

# Cloud logging (set to true for cloud deployment)
CLOUD_LOGGING_ENABLED=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Monitoring interval for cloud orchestrator (seconds)
MONITOR_INTERVAL_SECONDS=30

# ============================================
# OPERATIONAL MODES
# ============================================

# DRY_RUN: true = simulate actions, false = execute
# Always start with DRY_RUN=true for testing
DRY_RUN=true

# CLOUD_ENABLED: Enable cloud orchestration
CLOUD_ENABLED=true

# ============================================
# AWS CONFIGURATION (Optional - for S3/CloudWatch)
# ============================================

# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# ============================================
# AZURE CONFIGURATION (Optional - for Blob Storage)
# ============================================

# AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string
# AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
# AZURE_TENANT_ID=your_tenant_id

# ============================================
# GOOGLE CLOUD CONFIGURATION (Optional - for GCS)
# ============================================

# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json
# GCS_BUCKET_NAME=your_gcs_bucket

# ============================================
# REDIS CONFIGURATION (Optional - for distributed state)
# ============================================

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ============================================
# DATABASE CONFIGURATION (Optional - for persistent storage)
# ============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/ai_employee
# DATABASE_TYPE=postgresql

# ============================================
# MESSAGE QUEUE CONFIGURATION (Optional)
# ============================================

# RABBITMQ_URL=amqp://user:password@localhost:5672
# KAFKA_BROKERS=localhost:9092

# ============================================
# SECURITY SETTINGS
# ============================================

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Maximum concurrent tasks
MAX_CONCURRENT_TASKS=10

# Request timeout (seconds)
REQUEST_TIMEOUT=60

# ============================================
# NOTIFICATION SETTINGS (Optional)
# ============================================

# Email notifications for briefing ready
# NOTIFICATION_EMAIL=admin@example.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ============================================
# HEALTH CHECK ENDPOINTS
# ============================================

# Enable health check endpoint
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080

# ============================================
# METRICS & MONITORING
# ============================================

# Enable Prometheus metrics
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Enable distributed tracing
# TRACING_ENABLED=false
# TRACING_ENDPOINT=http://jaeger:14268/api/traces
