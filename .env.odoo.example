# =============================================================================
# ODOO INTEGRATION - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.odoo and fill in your actual credentials
# NEVER commit .env.odoo to version control
# 
# SECURITY: This file contains sensitive credentials
# - Store in secure location
# - Use secrets manager in production
# - Rotate credentials regularly
# =============================================================================

# -----------------------------------------------------------------------------
# ODOO CONNECTION (REQUIRED)
# -----------------------------------------------------------------------------

# Odoo instance URL (HTTPS recommended for production)
# Cloud Docker: https://odoo.yourcompany.com
# Local Docker: http://localhost:8069
ODOO_URL=https://odoo.yourcompany.com

# Odoo database name
ODOO_DB=odoo

# Odoo username (admin or dedicated API user)
ODOO_USERNAME=admin

# Odoo password or API key
# RECOMMENDED: Create dedicated API user with limited permissions
ODOO_PASSWORD=your_odoo_password_here

# Optional: Odoo API key (if using API key authentication)
# ODOO_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# INTEGRATION MODE (REQUIRED)
# -----------------------------------------------------------------------------

# Enable Odoo integration
ODOO_ENABLED=true

# DRY_RUN mode: true = simulate, false = execute
# ALWAYS start with DRY_RUN=true for testing
DRY_RUN=true

# -----------------------------------------------------------------------------
# CLOUD/LOCAL CONFIGURATION
# -----------------------------------------------------------------------------

# Base directory for cloud operations
CLOUD_BASE_DIR=.

# Default approver email (for audit logging)
DEFAULT_APPROVER=admin@localhost

# -----------------------------------------------------------------------------
# SECURITY SETTINGS
# -----------------------------------------------------------------------------

# Request timeout (seconds)
ODOO_TIMEOUT=30

# Maximum retry attempts
ODOO_MAX_RETRIES=3

# Retry base delay (seconds)
ODOO_RETRY_DELAY=1.0

# -----------------------------------------------------------------------------
# ODOO-SPECIFIC SETTINGS
# -----------------------------------------------------------------------------

# Default invoice type: out_invoice, in_invoice, out_refund, in_refund
DEFAULT_INVOICE_TYPE=out_invoice

# Default payment terms (days)
DEFAULT_PAYMENT_TERMS=30

# Default currency
DEFAULT_CURRENCY=USD

# Tax included in price? (true/false)
TAX_INCLUDED=false

# Default tax rate (%)
DEFAULT_TAX_RATE=10

# -----------------------------------------------------------------------------
# CRM SETTINGS
# -----------------------------------------------------------------------------

# Default lead stage (ID or name)
DEFAULT_LEAD_STAGE=new

# Default lead type: lead or opportunity
DEFAULT_LEAD_TYPE=lead

# Default probability for new leads (%)
DEFAULT_LEAD_PROBABILITY=10

# -----------------------------------------------------------------------------
# LOGGING SETTINGS
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log directory
LOG_DIR=Logs

# Enable transaction logging
TRANSACTION_LOGGING=true

# -----------------------------------------------------------------------------
# ADVANCED SETTINGS (OPTIONAL)
# -----------------------------------------------------------------------------

# Custom JSON-RPC endpoint (default: /jsonrpc)
# ODOO_JSONRPC_ENDPOINT=/jsonrpc

# Custom authentication endpoint
# ODOO_AUTH_ENDPOINT=/web/session/authenticate

# Enable debug mode
# ODOO_DEBUG=false

# Session timeout (seconds)
# ODOO_SESSION_TIMEOUT=3600

# -----------------------------------------------------------------------------
# PRODUCTION DEPLOYMENT
# -----------------------------------------------------------------------------
# For production, use environment variables or secrets manager:
#
# AWS Secrets Manager:
#   ODOO_PASSWORD=$(aws secretsmanager get-secret-value --secret-id odoo-password)
#
# Azure Key Vault:
#   ODOO_PASSWORD=$(az keyvault secret show --vault-name myvault --name odoo-password --query value)
#
# Docker secrets:
#   ODOO_PASSWORD_FILE=/run/secrets/odoo_password
#
# =============================================================================
